# ==============================================================================
# EGX Deep Analyst — Generator Scripts Secrets (EXAMPLE)
# ==============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ==============================================================================

# ── Z.ai GLM API ──────────────────────────────────────────────────────────────
# API key for Z.ai GLM model — used in aiAnalysisNode.js
# Get yours at: https://bigmodel.cn/usercenter/apikeys
ZAI_API_KEY=your_zai_api_key_here

# ── Discord Webhook ───────────────────────────────────────────────────────────
# Webhook URL for posting analysis results to Discord channel
# Create one in your Discord server: Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/CHANNEL_ID/WEBHOOK_TOKEN
