# ==============================================================================
# HomeLab — Environment Variables Template
# ==============================================================================
# Copy this file to .env and fill in your actual values.
# The .env file is gitignored and must NEVER be committed.
# ==============================================================================

# ── Tailscale Exit Node ────────────────────────────────────────────────────────
# Generate at: https://login.tailscale.com/admin/settings/keys
# Use a reusable, ephemeral auth key tagged for this node.
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Frigate NVR ───────────────────────────────────────────────────────────────
# The RTSP password for your camera streams.
FRIGATE_RTSP_PASSWORD=your_camera_rtsp_password

# ── PostgreSQL (n8n database) ─────────────────────────────────────────────────
# Superuser credentials (admin operations only, not used by n8n directly).
POSTGRES_USER=n8n_admin
POSTGRES_PASSWORD=change_me_strong_random_hex_password

# Application user credentials (used by n8n to connect to the database).
POSTGRES_NON_ROOT_USER=n8n_user
POSTGRES_NON_ROOT_PASSWORD=change_me_strong_random_hex_password

# ── n8n Workflow Automation ───────────────────────────────────────────────────
# Must match POSTGRES_NON_ROOT_USER / POSTGRES_NON_ROOT_PASSWORD above.
DB_POSTGRESDB_USER=n8n_user
DB_POSTGRESDB_PASSWORD=change_me_strong_random_hex_password
